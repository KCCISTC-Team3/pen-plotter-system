#include "Listener.h"
#include <stdio.h>  // printf, sprintf를 사용하기 위해 필수
#include <string.h> // strlen을 사용한다면 이것도 필요

extern osMessageQId Cmd_QueueHandle; // freertos.c에서 생성된 큐

void Listener_Init() {
	UART_StartReceive(); // 인터럽트 수신 시작
}

void Listener_Execute(void) {
	coordinate_t temp_data;
	char debug_buf[64]; // 디버깅용 문자열 버퍼

	if (data_ready_flag) {
		if (Parse_To_Struct(rx_buffer, &temp_data)) {

//			// 2. [추가] 큐에 넣기 전 데이터 확인용 UART 송신
//			// Parse_To_Struct가 성공한 직후의 데이터를 확인합니다.
//			sprintf(debug_buf,
//					"\r\n[Listener Debug] Queue In -> X:%d, Y:%d, Z:%d\r\n",
//					(int) temp_data.x, (int) temp_data.y, (int) temp_data.z);
//
//			HAL_UART_Transmit(&huart2, (uint8_t*) debug_buf, strlen(debug_buf),
//					100);

			// 구조체 전체를 큐로 복사해서 전송 (안전함) = xQueueSend
			if (xQueueSend((QueueHandle_t )Cmd_QueueHandle, &temp_data,
					0) == pdPASS) {
				data_ready_flag = 0;

				UART_StartReceive();
			}
		} else {
			data_ready_flag = 0;
			UART_StartReceive();
		}
	}
}

